#!/usr/bin/env bash
# Pre-push hook: enforce branch naming before pushing to remote
#
# Install (run once per clone):
#   git config core.hooksPath .githooks
#
# Branch naming convention:
#   feat/<description>     — New features
#   fix/<description>      — Bug fixes
#   docs/<description>     — Documentation only changes
#   refactor/<description> — Code refactoring
#
# Customise the regex below to require work item IDs:
#   Azure DevOps:  '^(feat|feature|fix)/AB[0-9]+-'
#   Atlassian Jira: '^(feat|feature|fix)/[A-Z]+-[0-9]+-'

set -euo pipefail

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Allow pushing to main/dev (for PR merges and CI)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "dev" ]; then
    exit 0
fi

# Enforce branch naming
# Default: branches must start with feat/, feature/, fix/, docs/, or refactor/
#
# To require work item IDs, replace the regex below. Examples:
#   Azure DevOps:  '^(feat|feature|fix)/AB[0-9]+-'
#   Jira:          '^(feat|feature|fix)/SHCO-[0-9]+-'
#
if ! echo "$BRANCH" | grep -qE '^(feat|feature|fix|docs|refactor)/'; then
    echo ""
    echo "  ❌ pre-push: branch '$BRANCH' doesn't match the required pattern."
    echo ""
    echo "  Branch must start with one of:"
    echo ""
    echo "    feat/<description>      — New features"
    echo "    fix/<description>       — Bug fixes"
    echo "    docs/<description>      — Documentation changes"
    echo "    refactor/<description>  — Code refactoring"
    echo ""
    echo "  Examples:"
    echo "    git checkout -b feat/announcement-banner"
    echo "    git checkout -b fix/login-redirect"
    echo "    git checkout -b docs/update-deployment-guide"
    echo "    git checkout -b refactor/shared-utils"
    echo ""
    echo "  Rename your branch:"
    echo "    git branch -m <new-name>"
    echo ""
    exit 1
fi
