#!/usr/bin/env bash
# Pre-commit hook: enforce branch naming and prevent direct commits to protected branches
#
# Install (run once per clone):
#   git config core.hooksPath .githooks
#
# Branch naming convention:
#   feat/<description>     — New features
#   fix/<description>      — Bug fixes
#   docs/<description>     — Documentation only changes
#   refactor/<description> — Code refactoring
#
# Work item linking (customise for your project):
#   Azure DevOps:  feat/AB<id>-<description>   → AB#<id> in commits
#   Atlassian Jira: feat/SHCO-<id>-<description> → SHCO-<id> in commits

set -euo pipefail

# ── Enforce protected branches ───────────────────────────────────────────────
BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "dev" ]; then
    echo ""
    echo "  ❌ pre-commit: direct commits to '$BRANCH' are not allowed."
    echo ""
    echo "  Create a feature branch and open a PR instead:"
    echo "    git checkout -b feat/<short-description>"
    echo ""
    echo "  Examples:"
    echo "    git checkout -b feat/announcement-banner"
    echo "    git checkout -b fix/login-redirect"
    echo ""
    exit 1
fi

# ── Enforce branch naming ────────────────────────────────────────────────────
# Customise this regex to match your project's conventions.
# Default: branches must start with feat/, feature/, fix/, docs/, or refactor/
#
# To require work item IDs (Azure DevOps):
#   '^(feat|feature|fix)/AB[0-9]+-'
#
# To require issue keys (Jira):
#   '^(feat|feature|fix)/[A-Z]+-[0-9]+-'
#
if ! echo "$BRANCH" | grep -qE '^(feat|feature|fix|docs|refactor)/'; then
    echo ""
    echo "  ❌ pre-commit: branch '$BRANCH' doesn't match the required pattern."
    echo ""
    echo "  Branch must start with one of:"
    echo ""
    echo "    feat/<description>      — New features"
    echo "    fix/<description>       — Bug fixes"
    echo "    docs/<description>      — Documentation changes"
    echo "    refactor/<description>  — Code refactoring"
    echo ""
    echo "  Examples:"
    echo "    git checkout -b feat/announcement-banner"
    echo "    git checkout -b fix/login-redirect"
    echo "    git checkout -b docs/update-deployment-guide"
    echo "    git checkout -b refactor/shared-utils"
    echo ""
    exit 1
fi

