#!/usr/bin/env bash
# Commit-msg hook: enforce Conventional Commits and work item linking
#
# Install (run once per clone):
#   git config core.hooksPath .githooks
#
# Commit message format:
#   <type>: <description>
#   [optional body]
#   [optional footer: work item reference]
#
# Valid types: feat, fix, docs, refactor, chore
#
# Work item linking (customise WORK_ITEM_PATTERN below):
#   Azure DevOps:   AB#<id>       (e.g., AB#117)
#   Atlassian Jira: SHCO-<id>    (e.g., SHCO-123)

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# ── Configuration ──────────────────────────────────────────────────────────
# Customise this for your project management tool:
#
# Azure DevOps:
WORK_ITEM_PATTERN='AB#[0-9]+'
BRANCH_ID_PATTERN='AB[0-9]+'
TOOL_NAME='Azure DevOps'
#
# Atlassian Jira (uncomment and replace SHCO with your project key):
# WORK_ITEM_PATTERN='SHCO-[0-9]+'
# BRANCH_ID_PATTERN='SHCO-[0-9]+'
# TOOL_NAME='Jira'
#
# To disable work item checking entirely, set:
# WORK_ITEM_PATTERN=''

# ── Skip merge commits and squash commits ──────────────────────────────────
if echo "$COMMIT_MSG" | grep -qE '^(Merge|Revert|Squashed) '; then
    exit 0
fi

# ── Enforce Conventional Commits format ────────────────────────────────────
if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|refactor|chore)(\(.+\))?: .+'; then
    echo ""
    echo "  ❌ commit-msg: invalid commit message format."
    echo ""
    echo "  Commit message must follow Conventional Commits:"
    echo ""
    echo "    <type>: <description>"
    echo ""
    echo "  Valid types: feat, fix, docs, refactor, chore"
    echo ""
    echo "  Examples:"
    echo "    feat: add announcement banner management"
    echo "    fix: resolve login redirect issue"
    echo "    docs: update deployment guide"
    echo "    refactor: extract shared pipeline template"
    echo "    chore: update dependencies"
    echo ""
    echo "  Your message: \"$COMMIT_MSG\""
    echo ""
    exit 1
fi

# ── Check for work item reference on feat/fix branches ─────────────────────
if [ -n "$WORK_ITEM_PATTERN" ]; then
    FULL_MSG=$(cat "$COMMIT_MSG_FILE")

    if echo "$BRANCH" | grep -qE '^(feat|feature|fix)/'; then
        BRANCH_ID=$(echo "$BRANCH" | grep -oE "$BRANCH_ID_PATTERN" | head -1)

        if [ -n "$BRANCH_ID" ] && ! echo "$FULL_MSG" | grep -qE "$WORK_ITEM_PATTERN"; then
            # Build the suggested reference from branch ID
            if [ "$TOOL_NAME" = "Azure DevOps" ]; then
                SUGGESTED_REF="AB#${BRANCH_ID#AB}"
            else
                SUGGESTED_REF="$BRANCH_ID"
            fi

            echo ""
            echo "  ⚠️  commit-msg: missing $TOOL_NAME work item reference."
            echo ""
            echo "  Your branch ($BRANCH) references $BRANCH_ID."
            echo "  Add a work item reference to your commit message:"
            echo ""
            echo "    git commit -m \"$(echo "$COMMIT_MSG") $SUGGESTED_REF\""
            echo ""
            echo "  This creates a bidirectional link between GitHub and $TOOL_NAME."
            echo ""
            exit 1
        fi
    fi
fi
