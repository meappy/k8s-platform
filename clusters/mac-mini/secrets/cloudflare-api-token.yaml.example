# Cloudflare API Token Secret
# Used for DNS-01 challenges with Let's Encrypt (optional)
#
# To create a Cloudflare API token:
# 1. Go to https://dash.cloudflare.com/profile/api-tokens
# 2. Create a token with Zone:DNS:Edit permissions
# 3. Copy the token value below
#
# Note: For the current setup, this is optional since we use
# Cloudflare Origin certificates on the Raspberry Pi.

apiVersion: v1
kind: Secret
metadata:
  name: cloudflare-api-token
  namespace: cert-manager
type: Opaque
stringData:
  api-token: "your-cloudflare-api-token-here"
